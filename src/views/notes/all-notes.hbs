<div class="row">
    {{#each notes}}
    <div class="col-md-3 mb-3">
        <div class="card">
            <div class="card-body">
                <h5>{{title}}</h5>
                <p>{{description}}</p>
            </div>

            <div class="card-footer">
                <a href="/notes/edit/{{_id}}" class="btn btn-outline-info btn-block">
                    Edit
                </a>

                <form action="/notes/delete/{{_id}}?_method=DELETE" method="POST" class="mt-2">
                    <input type="hidden" name="_method" value="DELETE">
                    <button type="submit" class="btn btn-outline-danger btn-block">
                        Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
    {{/each}}
</div>
